{
  "name": "service-marketplace-website",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,green \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "lint": "npm run lint --workspace client",
    "db:start": "powershell -ExecutionPolicy Bypass -File scripts/start-local-db.ps1",
    "db:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-db.ps1",
    "db:reset": "powershell -ExecutionPolicy Bypass -File scripts/reset-local-db.ps1",
    "db:generate": "npm run prisma:generate --workspace server",
    "db:migrate": "npm run db:migrate --workspace server",
    "db:seed": "npm run db:seed --workspace server",
    "db:reseed:marketplace": "npm run db:reseed:marketplace --workspace server",
    "db:studio": "npm run db:studio --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
